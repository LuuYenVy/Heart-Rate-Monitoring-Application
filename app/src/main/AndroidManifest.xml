        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HeartDiseasePrediction"

        tools:targetApi="31">
        <activity android:name=".Activities.UI.Auth.LoginActivity"
            android:exported="false"/>
        <activity android:name=".Activities.UI.Auth.SignUpInformationActivity"
            android:exported="false"/>
        <activity android:name=".Activities.UI.Auth.RegisterActivity"
            android:exported="false"/>
        <activity android:name=".Activities.UI.Doctor.main.AdminMainActivity"
            android:exported="false"/>
        <activity android:name=".Activities.UI.Doctor.appointment.AdminDetailAppointmentActivity"
            android:exported="false"/>
        <activity android:name=".Activities.UI.Doctor.chart.ChartActivity"
            android:exported="false"/>
        <activity android:name=".Activities.UI.Doctor.examination.PreCheckUpProcessActivity"
